<?xml version="1.0" encoding="utf-8"?>
<!--
Desktop publish: a self-contained native exe an admin runs on a regular Windows machine (no .NET
install needed). Content files (web/, appsettings.json) publish as loose files next to the exe —
exactly the wanted layout; games/ and logs/ are auto-created on first run:

  dotnet publish KnockBox.Server -p:PublishProfile=win-x64-desktop
  → KnockBox.Server/bin/publish/win-x64/  (copy this folder anywhere and run KnockBox.Server.exe)

Requires the MSVC C++ build tools ("Desktop development with C++") for the Native AOT link step.
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- PublishAot (set in the csproj) drives the output: a single self-contained native exe with
         trimming built in. PublishSingleFile/EnableCompressionInSingleFile would be redundant and an
         explicit PublishTrimmed=false would conflict (AOT requires trimming). Config binding and STJ
         polymorphism are already AOT-safe here via the source generators. -->
    <PublishDir>bin\publish\win-x64</PublishDir>
  </PropertyGroup>
</Project>
