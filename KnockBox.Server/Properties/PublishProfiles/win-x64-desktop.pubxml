<?xml version="1.0" encoding="utf-8"?>
<!--
Desktop publish: a self-contained single-file exe an admin runs on a regular Windows machine
(no .NET install needed). Content files (web/, appsettings.json) publish as loose files next to
the exe — exactly the wanted layout; games/ and logs/ are auto-created on first run:

  dotnet publish KnockBox.Server -p:PublishProfile=win-x64-desktop
  → KnockBox.Server/bin/publish/win-x64/  (copy this folder anywhere and run KnockBox.Server.exe)
-->
<Project>
  <PropertyGroup>
    <PublishProtocol>FileSystem</PublishProtocol>
    <Configuration>Release</Configuration>
    <TargetFramework>net10.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <PublishSingleFile>true</PublishSingleFile>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- Trimming is risky for config binding + System.Text.Json polymorphism, for zero benefit here. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishDir>bin\publish\win-x64</PublishDir>
  </PropertyGroup>
</Project>
