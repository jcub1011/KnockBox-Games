# Copy this file to `.env` (next to docker-compose.yml) and adjust the paths.
# `.env` is gitignored; this template is tracked. Both settings are optional.

# Stable host path for your game library. Mounted READ-ONLY — the server never writes here.
# Survives image updates and container recreation. Drop game folders in to publish them.
KNOCKBOX_GAMES_DIR=/srv/knockbox/games

# Persistent location for the pre-compressed asset cache (.br/.gz variants, built at max effort).
# Leave this UNSET to use the Docker-managed `knockbox-compressed` named volume (recommended for a
# plain `docker compose` host — zero setup, correct ownership). Set it to a host path to keep the
# cache on a chosen disk/dataset instead — e.g. on TrueNAS:
#   KNOCKBOX_COMPRESSED_DIR=/mnt/tank/knockbox/games-compressed
# A host path must be WRITABLE by the container's non-root user (UID 1654), e.g.
#   chown -R 1654 /mnt/tank/knockbox/games-compressed
# Otherwise the server can't write the cache and silently falls back to slower on-the-fly compression.
#KNOCKBOX_COMPRESSED_DIR=/srv/knockbox/games-compressed
